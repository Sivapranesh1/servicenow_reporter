# SMTP credentials - never commit real credentials
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=svc-reporter@example.com
SMTP_PASSWORD=changeme
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=svc-reporter@example.com
SMTP_FROM_NAME=ServiceNow Reporter Bot

# Optional override of config file path
CONFIG_FILE=./config/config.yaml
